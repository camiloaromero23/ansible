
Host *
  AddKeysToAgent yes

Host ssh.dev.azure.com
  HostName ssh.dev.azure.com
  User git
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_rsa_finaipro

Host gitlab.com
  HostName gitlab.com
  User git
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_rsa

Host github.com
  HostName github.com
  User git
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_ed25519

Host finaipro.github.com
  HostName github.com
  User git
  AddKeysToAgent yes
  IdentitiesOnly yes
  IdentityFile ~/.ssh/id_ed25519_finaipro

Host github.com-andes
  HostName github.com
  User git
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_ed25519_andes
